## systemd unit for dizaster
## Save to: /etc/systemd/system/comms-mcp.service
## Enable: sudo systemctl daemon-reload && sudo systemctl enable --now comms-mcp

[Unit]
Description=COMMS-MCP — Centralised communication MCP server
After=network.target

[Service]
Type=simple
User=kamau
WorkingDirectory=/home/kamau/comms-mcp
EnvironmentFile=/home/kamau/comms-mcp/.env
ExecStart=/usr/bin/node src/index.js
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=comms-mcp
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target


