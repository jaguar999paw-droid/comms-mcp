# ── MCP Server ────────────────────────────────────────────────
MCP_PORT=3700
MCP_API_KEY=change-me-to-a-strong-secret

# ── Telnyx (primary SMS + Voice) ──────────────────────────────
TELNYX_API_KEY=KEY...
TELNYX_FROM_NUMBER=+1234567890        # Your Telnyx number

# ── Twilio (fallback SMS + Voice) ─────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1234567890

# ── Resend (Email) ────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=comms@yourdomain.com
EMAIL_FROM_NAME=COMMS-MCP

# ── Active providers ──────────────────────────────────────────
# Options: telnyx | twilio
SMS_PROVIDER=telnyx
VOICE_PROVIDER=telnyx

# ── Rate limiting ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=600000           # 10 minutes
RATE_LIMIT_MAX_PER_ID=5              # per identifier

# ── Privacy ───────────────────────────────────────────────────
LOG_LEVEL=info                        # debug | info | warn | error
AUDIT_LOG_PATH=./logs/audit.ndjson
